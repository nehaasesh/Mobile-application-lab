package com.example.temperatureconverter

import android.os.Bundle
import android.widget.Button
import android.widget.EditText
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity

class MainActivity : AppCompatActivity() {

    private lateinit var etTemperature: EditText
    private lateinit var btnCtoF: Button
    private lateinit var btnFtoC: Button
    private lateinit var tvResult: TextView

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        etTemperature = findViewById(R.id.etTemperature)
        btnCtoF = findViewById(R.id.btnCtoF)
        btnFtoC = findViewById(R.id.btnFtoC)
        tvResult = findViewById(R.id.tvResult)

        btnCtoF.setOnClickListener {
            convertCelsiusToFahrenheit()
        }

        btnFtoC.setOnClickListener {
            convertFahrenheitToCelsius()
        }
    }

    private fun convertCelsiusToFahrenheit() {
        val input = etTemperature.text.toString().trim()

        if (input.isEmpty()) {
            Toast.makeText(this, "Please enter a temperature", Toast.LENGTH_SHORT).show()
            return
        }

        val celsius = input.toDouble()
        val fahrenheit = (celsius * 9 / 5) + 32

        tvResult.text = "Result: %.2f °F".format(fahrenheit)
    }

    private fun convertFahrenheitToCelsius() {
        val input = etTemperature.text.toString().trim()

        if (input.isEmpty()) {
            Toast.makeText(this, "Please enter a temperature", Toast.LENGTH_SHORT).show()
            return
        }

        val fahrenheit = input.toDouble()
        val celsius = (fahrenheit - 32) * 5 / 9

        tvResult.text = "Result: %.2f °C".format(celsius)
    }
